<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Example.CityExplorer.Views.SettingsPage"
             Title="{Binding SettingsTitle}"
             BackgroundColor="#F7FBFF">
    <Grid RowDefinitions="Auto,Auto,*" Padding="18,18,18,12" RowSpacing="14">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F7FBFF" Offset="0.0" />
                <GradientStop Color="#D6E8F8" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Label Text="{Binding PageHeading}"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="#1F6FB2" />

        <Border Grid.Row="1"
                Padding="18"
                BackgroundColor="White"
                Stroke="#D6E2F0"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 8">
            <VerticalStackLayout Spacing="10">
                <Label Text="{Binding LanguageLabel}"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#1F6FB2" />
                <Picker ItemsSource="{Binding Languages}"
                        SelectedItem="{Binding CurrentLanguage, Mode=TwoWay}"
                        TextColor="#243B53"
                        Title="{Binding LanguageLabel}" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>