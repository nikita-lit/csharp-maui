<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Example.SnakeGame.SnakeGameStart"
             Title="Snake : Peamenüü">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25" VerticalOptions="Center">

            <Label Text="🐍"
                   FontSize="80"
                   HorizontalOptions="Center" />

            <Label Text="Snake"
                   FontSize="36"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,10"
                   Style="{DynamicResource GlobalLabelStyle}" />

            <Label x:Name="HighScoreLabel"
                   Text="Parim tulemus: 0"
                   FontSize="16"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"
                   Style="{DynamicResource GlobalLabelStyle}" />

            <Grid HorizontalOptions="Center">
                <Button
                    WidthRequest="250" HeightRequest="60"
                        CornerRadius="10"
                        Clicked="OnPlayClicked"
                        Style="{DynamicResource GlobalButtonStyle}" />
                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                       Spacing="10" InputTransparent="True">
                    <Image Source="play.png"
                           WidthRequest="24" HeightRequest="24"
                           VerticalOptions="Center" />
                    <Label x:Name="PlayText"
                           Text="Alusta mängu"
                           FontSize="20"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           Style="{DynamicResource GlobalButtonStyle}" />
                </HorizontalStackLayout>
            </Grid>

            <Grid HorizontalOptions="Center">
                <Button
                    WidthRequest="250" HeightRequest="60"
                        CornerRadius="10"
                        Clicked="OnStatsClicked"
                        Style="{DynamicResource GlobalButtonStyle}" />
                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                       Spacing="10" InputTransparent="True">
                    <Image Source="stats.png"
                           WidthRequest="24" HeightRequest="24"
                           VerticalOptions="Center" />
                    <Label x:Name="StatsText"
                           Text="Statistika"
                           FontSize="20"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           Style="{DynamicResource GlobalButtonStyle}" />
                </HorizontalStackLayout>
            </Grid>

            <Grid HorizontalOptions="Center">
                <Button
                    WidthRequest="250" HeightRequest="60"
                        CornerRadius="10"
                        Clicked="OnSettingsClicked"
                        Style="{DynamicResource GlobalButtonStyle}" />
                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                       Spacing="10" InputTransparent="True">
                    <Image Source="settings.png"
                           WidthRequest="24" HeightRequest="24"
                           VerticalOptions="Center" />
                    <Label x:Name="SettingsText"
                           Text="Seaded"
                           FontSize="20"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           Style="{DynamicResource GlobalButtonStyle}" />
                </HorizontalStackLayout>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
