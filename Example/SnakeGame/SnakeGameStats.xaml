<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Example.SnakeGame.SnakeGameStats"
             Title="Statistics">
    <ScrollView>
        <VerticalStackLayout Padding="24"
                             Spacing="18"
                             VerticalOptions="Center">

            <Label x:Name="StatsTitleLabel"
                   Text="Statistics"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,16"
                   Style="{DynamicResource GlobalLabelStyle}" />

            <Border Padding="18"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    Style="{DynamicResource GlobalBorderStyle}" >
                <VerticalStackLayout Spacing="14">
                    <Label Text="{Binding PlayerNameText}"
                           FontSize="18"
                           FontAttributes="Bold"
                           Style="{DynamicResource GlobalLabelStyle}" />

                    <Label Text="{Binding GamesPlayedText}"
                           FontSize="16"
                           Style="{DynamicResource GlobalLabelStyle}" />

                    <Label Text="{Binding LastScoreText}"
                           FontSize="16"
                           Style="{DynamicResource GlobalLabelStyle}" />

                    <Label Text="{Binding BestScoreText}"
                           FontSize="16"
                           Style="{DynamicResource GlobalLabelStyle}" />
                </VerticalStackLayout>
            </Border>

            <Button
                   WidthRequest="60"
                   HeightRequest="60"
                   CornerRadius="10"
                   ImageSource="back.png"
                   ContentLayout="Top,0"
                   Clicked="OnBackClicked"
                   Style="{DynamicResource GlobalButtonStyle}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
