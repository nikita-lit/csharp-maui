<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Example.FoodDetailPage"
             Title="Food Details"
             Shell.NavBarIsVisible="True">

    <ScrollView>
        <Grid RowDefinitions="300, Auto, *" Padding="0">
            <Image Grid.Row="0"
                   Source="{Binding ImageUrl}"
                   Aspect="AspectFill"
                   HeightRequest="300" />

            <BoxView Grid.Row="0"
                     HeightRequest="300"
                     VerticalOptions="Fill">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Transparent" Offset="0.6" />
                        <GradientStop Color="#CC000000" Offset="1.0" />
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>

            <Frame Grid.Row="1" Grid.RowSpan="2"
                   Margin="0,-30,0,0"
                   Padding="25,35"
                   CornerRadius="30"
                   BackgroundColor="White"
                   HasShadow="False"
                   BorderColor="Transparent">
                
                <VerticalStackLayout Spacing="20">
                    <Label Text="{Binding Name}"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="#C0392B"
                           HorizontalOptions="Start" />

                    <BoxView HeightRequest="2" 
                             WidthRequest="60" 
                             Color="#C0392B" 
                             HorizontalOptions="Start" />

                    <Label Text="{Binding Description}"
                           FontSize="18"
                           FontAttributes="Italic"
                           TextColor="#666666" />

                    <Label x:Name="AboutLabel"
                           Text="About this dish"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#333333"
                           Margin="0,10,0,0" />

                    <Label Text="{Binding DetailInfo}"
                           FontSize="16"
                           LineHeight="1.4"
                           TextColor="#444444" />

                    <Button x:Name="BackButton"
                            Text="Back to Gallery"
                            Clicked="OnBackClicked"
                            BackgroundColor="#C0392B"
                            TextColor="White"
                            CornerRadius="25"
                            HeightRequest="50"
                            Margin="0,30,0,0"
                            FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </ScrollView>
</ContentPage>
