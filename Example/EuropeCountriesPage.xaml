<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Example"
             x:Class="Example.EuropeCountriesPage"
             Title="Euroopa Riigid">
    <VerticalStackLayout Padding="15" Spacing="10">
        <Label Text="Lisa või muuda riiki" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" />
        
        <Entry x:Name="NameEntry" Placeholder="Riigi nimi (nt Eesti)" />
        <Entry x:Name="CapitalEntry" Placeholder="Pealinn (nt Tallinn)" />
        <Entry x:Name="PopulationEntry" Placeholder="Rahvaarv (nt 1331824)" Keyboard="Numeric" />

        <Button Text="Vali pilt" Clicked="PickImage_Clicked" BackgroundColor="LightBlue" TextColor="Black" />
        <Label x:Name="ImageStatusLabel" Text="Pilti pole valitud (kasutatakse vaikimisi pilti)" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
        <Image x:Name="FlagPreview" Source="bob.jpg" HeightRequest="100" Aspect="AspectFit" HorizontalOptions="Center" />

        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
            <Button Text="Lisa" Clicked="Add_Clicked" BackgroundColor="LightGreen" TextColor="Black" />
            <Button Text="Salvesta" Clicked="Save_Clicked" BackgroundColor="LightBlue" TextColor="Black" />
            <Button Text="Kustuta valitud" Clicked="Delete_Clicked" BackgroundColor="LightPink" TextColor="Black" />
        </HorizontalStackLayout>

        <BoxView HeightRequest="1" Color="LightGray" Margin="0,5" />

        <ListView x:Name="CountriesListView" 
                  HasUnevenRows="True" 
                  ItemTapped="List_ItemTapped"
                  ItemSelected="CountriesListView_ItemSelected">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:Country">
                    <ViewCell>
                        <Grid Padding="10" ColumnDefinitions="70, *">
                            <Image Source="{Binding Flag}" 
                                   WidthRequest="60" 
                                   HeightRequest="40" 
                                   Aspect="AspectFit"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="10,0,0,0">
                                <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding Capital}" FontSize="14" TextColor="Gray" />
                            </VerticalStackLayout>
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </VerticalStackLayout>
</ContentPage>
