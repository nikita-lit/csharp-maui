<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Example.SnakeGame.SnakeGameSettings"
             Title="Snake : Seaded">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20" VerticalOptions="Center">
            <Label x:Name="SettingsTitleLabel"
                   Text="Seaded"
                   FontSize="28" FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"
                   Style="{DynamicResource GlobalLabelStyle}" />

            <Label x:Name="LanguageLabel" Text="Keel:" FontSize="16"
                   Style="{DynamicResource GlobalLabelStyle}" />
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Start">
                    <Button x:Name="LanguageButton"
                            Text="🇪🇪 Eesti"
                            Clicked="OnLanguageClicked"
                            WidthRequest="100" HeightRequest="45" CornerRadius="8"
                            FontSize="13"
                            FontAttributes="Bold"
                            HorizontalOptions="Start"
                            Style="{DynamicResource GlobalButtonStyle}" />
            </HorizontalStackLayout>

            <Label x:Name="NameLabel" Text="Mängija nimi:" FontSize="16"
                   Style="{DynamicResource GlobalLabelStyle}" />
            <Entry x:Name="PlayerNameEntry"
                   Text="{Binding PlayerName}"
                   Placeholder="Sisesta nimi"
                   FontSize="16"
                   MaxLength="20"
                   Style="{DynamicResource GlobalEntryStyle}" />

            <Label x:Name="ThemeLabel" Text="Teema:" FontSize="16" Margin="0,10,0,0"
                   Style="{DynamicResource GlobalLabelStyle}" />
            <HorizontalStackLayout x:Name="ThemeButtons" Spacing="10" HorizontalOptions="Start">
                <Button x:Name="LightBtn" Text="Hele"
                        CommandParameter="Hele"
                        WidthRequest="100" HeightRequest="45" CornerRadius="8"
                        Clicked="OnThemeSelected"
                        Style="{DynamicResource GlobalButtonStyle}" />
                <Button x:Name="DarkBtn" Text="Tume"
                        CommandParameter="Tume"
                        WidthRequest="100" HeightRequest="45" CornerRadius="8"
                        Clicked="OnThemeSelected"
                        Style="{DynamicResource GlobalButtonStyle}" />
                <Button x:Name="ColorfulBtn" Text="Värviline"
                        CommandParameter="Värviline"
                        WidthRequest="100" HeightRequest="45" CornerRadius="8"
                        Clicked="OnThemeSelected"
                        Style="{DynamicResource GlobalButtonStyle}" />
            </HorizontalStackLayout>

            <Label x:Name="SpeedLabel" Text="Kiirus:" FontSize="16" Margin="0,10,0,0"
                   Style="{DynamicResource GlobalLabelStyle}" />
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Start">
                <Button x:Name="SlowBtn" Text="Aeglane"
                        CommandParameter="300"
                        WidthRequest="100" HeightRequest="45" CornerRadius="8"
                        Clicked="OnSpeedSelected"
                        Style="{DynamicResource GlobalButtonStyle}" />
                <Button x:Name="NormalBtn" Text="Normaalne"
                        CommandParameter="200"
                        WidthRequest="100" HeightRequest="45" CornerRadius="8"
                        Clicked="OnSpeedSelected"
                        Style="{DynamicResource GlobalButtonStyle}" />
                <Button x:Name="FastBtn" Text="Kiire"
                        CommandParameter="120"
                        WidthRequest="100" HeightRequest="45" CornerRadius="8"
                        Clicked="OnSpeedSelected"
                        Style="{DynamicResource GlobalButtonStyle}" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="50" Background="Transparent"></BoxView>
            
            <HorizontalStackLayout Spacing="10" 
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center">
                <Button
                    WidthRequest="60"
                    HeightRequest="60"
                    CornerRadius="10"
                    ImageSource="back.png"
                    ContentLayout="Top,0"
                    Clicked="OnBackClicked"
                    Style="{DynamicResource GlobalButtonStyle}" />
                
                <Button x:Name="SaveButton" Text="Salvesta"
                        WidthRequest="200" HeightRequest="60" CornerRadius="10"
                        FontSize="18" FontAttributes="Bold"
                        Clicked="OnSaveClicked"
                        Style="{DynamicResource GlobalButtonStyle}" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
