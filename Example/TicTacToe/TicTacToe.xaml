<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Example.TicTacToe.TicTacToe"
             Title="Trips-Traps-Trull"
             BackgroundColor="White">
       <ScrollView>
       <VerticalStackLayout Padding="20" Spacing="15">
              <Label Text="Trips-Traps-Trull" 
                     FontSize="32" 
                     FontAttributes="Bold" 
                     HorizontalOptions="Center" />

              <HorizontalStackLayout x:Name="StatsLayout" 
                                   Spacing="20" 
                                   HorizontalOptions="Center">
                     <Label x:Name="DrawsLabel" 
                            Text="Viigid: 0" 
                            FontSize="18" 
                            FontAttributes="Bold" 
                            TextColor="Gray" />
              </HorizontalStackLayout>

              <Label x:Name="CurrentPlayerLabel" 
                     Text="Kord: " 
                     FontSize="20" 
                     HorizontalOptions="Center" 
                     Margin="0,10,0,0" 
                     TextColor="Black" />

              <Border BackgroundColor="Gray" 
                     Padding="0" 
                     HorizontalOptions="Center" 
                     VerticalOptions="Center">
                     <Grid x:Name="GridBoard" 
                            WidthRequest="300" 
                            HeightRequest="300" 
                            BackgroundColor="LightGray" 
                            ColumnSpacing="2" 
                            RowSpacing="2" />
              </Border>
       </VerticalStackLayout>
       </ScrollView>
</ContentPage>