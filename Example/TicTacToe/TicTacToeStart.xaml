<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Example.TicTacToe.TicTacToeStart"
             Title="Trips-Traps-Trull : Peamenüü">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="30" VerticalOptions="Center">
            <Image Source="tic_tac_toe.png" WidthRequest="256" HeightRequest="256" HorizontalOptions="Center" />

            <Label Text="Trips-Traps-Trull" 
                   FontSize="36" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   Margin="0,0,0,40" />

            <Grid HorizontalOptions="Center">
                <Button BackgroundColor="#4CAF50" WidthRequest="250" HeightRequest="60" CornerRadius="10" Clicked="OnPlayClicked" />
                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" InputTransparent="True">
                    <Image Source="play.png" WidthRequest="24" HeightRequest="24" VerticalOptions="Center" />
                    <Label Text="Alusta mängu" TextColor="White" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Grid>

            <Grid HorizontalOptions="Center">
                <Button BackgroundColor="#2196F3" WidthRequest="250" HeightRequest="60" CornerRadius="10" Clicked="OnSettingsClicked" />
                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" InputTransparent="True">
                    <Image Source="settings.png" WidthRequest="24" HeightRequest="24" VerticalOptions="Center" />
                    <Label Text="Seaded" TextColor="White" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Grid>
            
            <Grid HorizontalOptions="Center">
                <Button BackgroundColor="#FF9800" WidthRequest="250" HeightRequest="60" CornerRadius="10" Clicked="OnStatsClicked" />
                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" InputTransparent="True">
                    <Image Source="stats.png" WidthRequest="24" HeightRequest="24" VerticalOptions="Center" />
                    <Label Text="Statistika" TextColor="White" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
