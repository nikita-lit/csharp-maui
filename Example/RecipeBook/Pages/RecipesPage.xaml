<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Example.RecipeBook.Pages.RecipesPage"
             Title="Minu retseptid"
             BackgroundColor="#FDFCFB">
    <Grid RowDefinitions="Auto,*" Padding="0,12,0,0" RowSpacing="10">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FDFCFB" Offset="0.0" />
                <GradientStop Color="#E2D1C3" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid RowDefinitions="Auto,Auto,Auto" Padding="22,6,22,4" RowSpacing="8">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                <Label Text="Minu retseptid"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#C0392B" />
                
                <Button Grid.Column="1"
                        Text="Lisa uus"
                        Clicked="OpenNewRecipeButton_Clicked"
                        BackgroundColor="#FDFCFB"
                        TextColor="#C0392B"
                        BorderColor="#E0E0E0"
                        BorderWidth="1"
                        CornerRadius="22" />
                
                <Label x:Name="RecipeCountLabel"
                       Grid.Row="1"
                       Grid.ColumnSpan="2"
                       TextColor="#7A7A7A"
                       FontSize="13" />
            </Grid>
            
            <SearchBar x:Name="RecipeSearchBar"
                       Grid.Row="1"
                       Placeholder="Otsi nime, kategooria või kirjelduse järgi"
                       TextChanged="RecipeSearchBar_TextChanged"
                       BackgroundColor="White"
                       TextColor="#4A4A4A" />
            <Label Grid.Row="2"
                   Text="Vali retsept, et näha kirjeldust."
                   TextColor="#7A7A7A"
                   FontSize="13" />
        </Grid>

        <CollectionView x:Name="RecipesCollectionView"
                        Grid.Row="1"
                        IsGrouped="True"
                        SelectionMode="None"
                        BackgroundColor="Transparent">
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="24,50" Spacing="8">
                    <Label Text="Retsepte ei leitud"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#C0392B"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Lisa uus retsept või muuda otsingut."
                           TextColor="#7A7A7A"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate>
                    <Grid Padding="18,10" BackgroundColor="#E2D1C3">
                        <Label Text="{Binding Title}"
                               FontSize="19"
                               FontAttributes="Bold"
                               TextColor="#C0392B" />
                    </Grid>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView Margin="14,4">
                        <Border BackgroundColor="White"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="RecipeCard_Tapped" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="86,*,Auto" Padding="14,10">
                                <Image Source="{Binding ImageUrl}"
                                       WidthRequest="70"
                                       HeightRequest="70"
                                       Aspect="AspectFill"
                                       Grid.Column="0" />

                                <VerticalStackLayout Grid.Column="1"
                                                     VerticalOptions="Center"
                                                     Spacing="5">
                                    <Label Text="{Binding Name}"
                                           FontAttributes="Bold"
                                           FontSize="17"
                                           TextColor="#4A4A4A" />
                                    <Label Text="{Binding Category}"
                                           FontSize="13"
                                           TextColor="#7A7A7A" />
                                    <Label Text="{Binding Description}"
                                           FontSize="13"
                                           TextColor="#4A4A4A"
                                           MaxLines="2" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
