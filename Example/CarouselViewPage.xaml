<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Example.CarouselViewPage"
             Title="Italian Cuisine Gallery">
    <Grid RowDefinitions="Auto,*,Auto,Auto" Padding="0">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FDFCFB" Offset="0.0" />
                <GradientStop Color="#E2D1C3" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Button Grid.Row="0"
                x:Name="LanguageButton"
                Text="🇬🇧 English"
                Clicked="OnLanguageClicked"
                BackgroundColor="#C0392B"
                TextColor="White"
                CornerRadius="20"
                FontSize="14"
                Padding="20,8"
                FontAttributes="Bold"
                HorizontalOptions="End"
                Margin="0,10,15,0" />

        <CarouselView Grid.Row="1"
                      x:Name="FoodCarousel"
                      IndicatorView="FoodIndicator"
                      Loop="True"
                      Margin="5,0"
                      HeightRequest="400">

            <CarouselView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8,15">
                        <Frame BackgroundColor="White"
                               CornerRadius="25"
                               Padding="0"
                               HasShadow="True"
                               BorderColor="#E0E0E0">

                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFoodTapped" />
                            </Frame.GestureRecognizers>

                            <VerticalStackLayout Spacing="0">
                                <Frame Padding="0"
                                       CornerRadius="25"
                                       IsClippedToBounds="True"
                                       HasShadow="False"
                                       HeightRequest="220">
                                    <Image Source="{Binding ImageUrl}"
                                           Aspect="AspectFill"
                                           HeightRequest="220" />
                                </Frame>

                                <Label Text="{Binding Name}"
                                       FontSize="26"
                                       FontAttributes="Bold"
                                       TextColor="#C0392B"
                                       HorizontalOptions="Center"
                                       Margin="15,18,15,5" />

                                <Label Text="{Binding Description}"
                                       FontSize="15"
                                       TextColor="#4A4A4A"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       Margin="15,0,15,10" />

                                <Label Text="{Binding TapHint}"
                                       FontSize="12"
                                       TextColor="#7A7A7A"
                                       HorizontalOptions="Center"
                                       Margin="15,5,15,18"
                                       Opacity="0.8" />
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>

        <IndicatorView Grid.Row="2"
                       x:Name="FoodIndicator"
                       IndicatorColor="#D0D0D0"
                       SelectedIndicatorColor="#C0392B"
                       IndicatorSize="12"
                       HorizontalOptions="Center"
                       Margin="0,0,0,10" />

        <Grid HorizontalOptions="Center" Grid.Row="3">
            <Button BackgroundColor="#FF9800" WidthRequest="250" HeightRequest="60" CornerRadius="10" Clicked="OnAutoScrollToggle" />
            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" InputTransparent="True">
                <Image x:Name="AutoScrollIcon" Source="pause.png" WidthRequest="24" HeightRequest="24" VerticalOptions="Center" />
                <Label Text="Auto-scroll" TextColor="White" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
